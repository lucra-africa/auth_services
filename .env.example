# Application
APP_NAME=poruta-auth
APP_ENV=development
APP_PORT=8050
APP_DEBUG=true

# Database (MongoDB)
MONGO_URI=mongodb://localhost:27017
MONGO_URI_FALLBACK=mongodb+srv://user:password@cluster.mongodb.net/?appName=MyCluster
MONGO_DB=poruta_auth

# JWT
JWT_SECRET_KEY=change-me-minimum-32-characters-long
JWT_ALGORITHM=RS256
JWT_PRIVATE_KEY_PATH=keys/jwt-private.pem
JWT_PUBLIC_KEY_PATH=keys/jwt-public.pem
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Email adfa(Zoho SMTP — SSL/TLS on port 465)
SMTP_HOST=smtp.zoho.com
SMTP_PORT=465
SMTP_USE_SSL=true
SMTP_USERNAME=support@poruta.com
SMTP_PASSWORD=change-me
SMTP_FROM_EMAIL=support@poruta.com
SMTP_FROM_NAME=Poruta

# Frontend
FRONTEND_URL=http://localhost:9000

# Admin Seed (optional — auto-creates admin on first run)
ADMIN_EMAIL=descartes.tuyishime@poruta.com
ADMIN_PASSWORD=Integrity@1234

# CORS      
CORS_ORIGINS=http://localhost:9000,http://localhost:3000

# Service-to-service API key (for poruta-backend)
SERVICE_API_KEY=change-me-in-production